def check_tool_availability(runner):
    """Check and display tool availability."""
    status = runner.check_tools(ALL_TOOLS)
    print_tool_status(status)

    available = sum(1 for v in status.values() if v)
    total = len(status)
    log_info(f"Tools available: {available}/{total}")

    # Minimum required
    essentials = ['curl', 'dig', 'nmap']
    missing_essentials = [t for t in essentials if not status.get(t)]
    if missing_essentials:
        log_warning(f"Missing essential tools: {', '.join(missing_essentials)}")
        log_warning("Run the install script: sudo bash install.sh")

    return status


