#  CONFIG FILE LOADING
# ═══════════════════════════════════════════════════════════════════════════════

def load_config_file(filepath):
    """Load config from YAML or JSON file. Returns dict."""
    if not filepath or not os.path.exists(filepath):
        return {}
    try:
        with open(filepath) as f:
            content = f.read()
        # Try JSON first
        import json
        try:
            return json.loads(content)
        except json.JSONDecodeError:
            pass
        # Try YAML
        try:
            import yaml
            return yaml.safe_load(content) or {}
        except ImportError:
            # YAML not installed, try simple key:value parsing
            config = {}
            for line in content.split('\n'):
                line = line.strip()
                if not line or line.startswith('#'):
                    continue
                if ':' in line:
                    key, val = line.split(':', 1)
                    key = key.strip().replace('-', '_')
                    val = val.strip()
                    # Type conversion
                    if val.lower() in ('true', 'yes'):
                        val = True
                    elif val.lower() in ('false', 'no'):
                        val = False
                    elif val.isdigit():
                        val = int(val)
                    config[key] = val
            return config
    except Exception:
        return {}


def merge_config(args, file_config):
    """Merge config file values into args (CLI takes priority)."""
    defaults = {
        'threads': 50, 'timeout': 600, 'rate_limit': 150,
        'passive': False, 'quick': False, 'verbose': False,
        'tor': False, 'resume': False,
    }
    for key, default_val in defaults.items():
        cli_val = getattr(args, key, None)
        # If CLI arg is at default, use config file value
        if cli_val == default_val and key in file_config:
            setattr(args, key, file_config[key])

    # String args: only override if CLI is None/empty
    for key in ['proxy', 'resolvers', 'wordlist', 'nuclei_templates',
                'output', 'scope_file', 'notarget', 'skip']:
        cli_val = getattr(args, key, None)
        if not cli_val and key in file_config:
            setattr(args, key, file_config[key])

    # Headers from config file
    if not args.header and 'headers' in file_config:
        h = file_config['headers']
        args.header = h if isinstance(h, list) else [h]


